# 应用配置
APP_NAME=CareerCopilot
DEBUG=true
HOST=0.0.0.0
PORT=8000

# LLM配置
LLM_PROVIDER=mimo
LLM_MODEL=mimo-v2.5-pro
MIMO_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Embedding配置
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# RAG配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3
SIMILARITY_THRESHOLD=0.3
MAX_CONTEXT_LENGTH=3000

# 向量存储配置
VECTOR_STORE_TYPE=faiss
